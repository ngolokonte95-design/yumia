# API YUMIA — copier vers apps/api/.env
NODE_ENV=development
API_PORT=4000
API_GLOBAL_PREFIX=api

DATABASE_URL=postgresql://yumia:yumia@localhost:5432/yumia?schema=public
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_NODE=http://localhost:9200

# IA — anthropic | mock
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL_SMART=claude-sonnet-4-6
AI_MODEL_FAST=claude-haiku-4-5
AI_MAX_TOKENS=1024

# ⚠️  OBLIGATOIRE en prod — générer avec : openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Email transactionnel (optionnel en dev — OTP logué console si absent)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=YUMIA <noreply@yumia.app>

# CORS — liste d'origines autorisées en prod (séparées par virgule)
# Laisser vide pour autoriser toutes les origines (dev uniquement)
ALLOWED_ORIGINS=

# Stockage photos — disk (dev) | s3 (prod)
STORAGE_PROVIDER=disk
STORAGE_PUBLIC_BASE_URL=http://localhost:4000
AWS_REGION=eu-west-3
AWS_S3_BUCKET=yumia-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optionnel : endpoint S3-compatible (MinIO, Cloudflare R2, etc.)
# AWS_S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com

# OAuth Google — clientId depuis console.cloud.google.com (API & Services → Identifiants)
GOOGLE_CLIENT_ID=

# Sentry — DSN depuis sentry.io → Paramètres du projet → SDK Setup → DSN
SENTRY_DSN=

# Niveau de log : trace | debug | info | warn | error (défaut : debug en dev, info en prod)
LOG_LEVEL=

# Admins — emails autorisés à créer des lieux via POST /api/places (séparés par virgule)
ADMIN_EMAILS=

# RevenueCat — secret de signature des webhooks (Dashboard → Integrations → Webhooks → Secret)
REVENUECAT_WEBHOOK_SECRET=

# Rate limiting global (optionnel — défauts : TTL 60 s, 120 req/fenêtre)
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=120
# THROTTLE_SKIP=true  ← NE PAS UTILISER EN PRODUCTION (tests uniquement)
