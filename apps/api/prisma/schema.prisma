model Place {
  id          String   @id @default(uuid())
  name        String
  universe    Universe

  lat         Float
  lng         Float
  city        String
  countryCode String

  rating      Float    @default(0)
  priceTier   Int      @default(2) // 1..4
  photoUrls   String[] @default([])

  // Attributs exploités par les moteurs IA (terrasse, kid_friendly, halal…).
  tags        String[] @default([])
  metadata    Json     @default("{}")

  // Provenance : 'seed' (données locales) ou 'google' (hydraté à la demande).
  // providerPlaceId déduplique les lieux importés (NULL pour les lieux seed).
  provider        String  @default("seed")
  providerPlaceId String? @unique
  address         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  visits      Visit[]
  savedBy     SavedPlace[]

  @@index([universe])
  @@index([city, universe])
  @@index([countryCode])
  // Bounding-box pre-filter for geo queries (nearbyViaPg, trending)
  @@index([lat, lng])
}

// ----------------------------------------------------------------------------
// Activité utilisateur : visites, sauvegardes
// ----------------------------------------------------------------------------

enum VisitFeedback {
  loved // 😍
  neutral // 😐
  disliked // 😕
}

model Visit {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place          @relation(fields: [placeId], references: [id], onDelete: Cascade)
  visitedAt DateTime       @default(now())
  feedback  VisitFeedback?
  xpAwarded Int            @default(0)
  notes     String?

  @@index([userId, visitedAt])
  @@index([placeId])
}

model SavedPlace {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  listName  String   @default("a_essayer")
  createdAt DateTime @default(now())

  @@unique([userId, placeId, listName])
  @@index([userId])
}

// ----------------------------------------------------------------------------
// Gamification : badges, streaks
// ----------------------------------------------------------------------------

model EarnedBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey  String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeKey])
  @@index([userId])
}

model Streak {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  current         Int      @default(0)
  best            Int      @default(0)
  lastActivityDay DateTime?
  freezesLeft     Int      @default(0) // YUMIA Plus
  updatedAt       DateTime @updatedAt

  // Optimise la requête cron "danger de streak" qui filtre sur current > 0 + lastActivityDay
  @@index([current, lastActivityDay])
}

// ----------------------------------------------------------------------------
// Réinitialisation de mot de passe
// ----------------------------------------------------------------------------

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ----------------------------------------------------------------------------
// Group Mode (viralité intégrée)
// ----------------------------------------------------------------------------

enum GroupStatus {
  waiting    // en attente que d'autres rejoignent
  voting     // l'hôte a lancé les suggestions, vote en cours
  done       // un lieu a été choisi
}

model GroupSession {
  id             String      @id @default(uuid())
  inviteCode     String      @unique
  status         GroupStatus @default(waiting)
  createdById    String?
  suggestions    Json        @default("[]") // PlaceId[]
  decidedPlaceId String?
  createdAt      DateTime    @default(now())
  members        GroupMember[]

  @@index([inviteCode])
  // Optimise le cron de nettoyage : filtre sur status + createdAt
  @@index([status, createdAt])
}

model GroupMember {
  id        String       @id @default(uuid())
  sessionId String
  session   GroupSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Votes : { placeId: 'like' | 'dislike' }
  votes     Json         @default("{}")
  joinedAt  DateTime     @default(now())

  @@index([sessionId])
}

// ----------------------------------------------------------------------------
// Modèle économique : partenariats établissements, billetterie, guides
// ----------------------------------------------------------------------------

/// Établissement partenaire — boost payant des suggestions + billetterie.
model Venue {
  id             String    @id @default(uuid())
  placeId        String?   // lien optionnel vers un Place existant
  name           String
  city           String?
  countryCode    String?
  // Boost des suggestions : 0 = aucun, 3 = maximal. Expire à boostExpiresAt.
  boostLevel     Int       @default(0)
  boostExpiresAt DateTime?
  businessPlan   String    @default("basic") // basic | pro | enterprise
  commissionRate Float     @default(0.15)
  /// Événement mis en avant pour la billetterie (optionnel).
  eventName      String?
  eventDate      DateTime?
  ticketPrice    Float?
  photoUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tickets        Ticket[]

  @@index([boostLevel])
  @@index([placeId])
}

/// Billet de club / soirée vendu via YUMIA (commission 15%).
model Ticket {
  id         String   @id @default(uuid())
  venueId    String
  venue      Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  eventId    String
  userId     String?
  quantity   Int      @default(1)
  unitPrice  Float
  totalPrice Float
  commission Float    // part YUMIA (15%)
  // paiement réel branché plus tard (Stripe) — statut applicatif pour l'instant
  status     String   @default("pending") // pending | paid | cancelled
  createdAt  DateTime @default(now())

  @@index([venueId])
  @@index([userId])
  @@index([eventId])
}

// ----------------------------------------------------------------------------
// Pipeline d'enrichissement — menus, événements, jobs
// ----------------------------------------------------------------------------

/// Carte des menus d'un lieu (une par lieu et par langue).
model PlaceMenu {
  id        String     @id @default(uuid())
  placeId   String
  language  String     @default("fr")
  source    String     @default("manual") // 'manual' | 'ai_extract' | 'scrape' | 'uber_eats'
  updatedAt DateTime   @updatedAt
  createdAt DateTime   @default(now())
  items     MenuItem[]

  @@unique([placeId, language])
  @@index([placeId])
}

/// Plat / boisson sur la carte d'un lieu.
model MenuItem {
  id          String    @id @default(uuid())
  menuId      String
  menu        PlaceMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float?
  currency    String    @default("EUR")
  category    String?   // 'entrée' | 'plat' | 'dessert' | 'boisson' | 'snack' | 'autre'
  photoUrl    String?
  tags        String[]  @default([])  // ['végétarien','halal','sans_gluten'…]
  available   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([menuId])
  @@index([menuId, category])
}

/// Événement lié à un lieu (concert, feu d'artifice, soirée thématique…).
model PlaceEvent {
  id          String   @id @default(uuid())
  placeId     String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  price       Float?
  currency    String   @default("EUR")
  ticketUrl   String?
  photoUrl    String?
  source      String   @default("manual") // 'manual' | 'ticketmaster' | 'eventbrite' | 'facebook'
  externalId  String?  // ID dans le système source (évite les doublons)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([placeId, source, externalId])
  @@index([placeId, startAt])
  @@index([startAt])
}

/// Avis utilisateur sur un lieu (texte + note 1-5).
model PlaceReview {
  id        String   @id @default(uuid())
  placeId   String
  userId    String
  rating    Int      // 1..5
  body      String?  // texte optionnel
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([placeId, userId])
  @@index([placeId])
  @@index([userId])
}

/// Suivi des jobs d'enrichissement (menu photo → IA, fetch événements…).
model EnrichmentJob {
  id        String   @id @default(uuid())
  placeId   String
  type      String   // 'menu_photo' | 'menu_scrape' | 'events_fetch' | 'photo_tag'
  status    String   @default("pending") // 'pending' | 'running' | 'done' | 'failed'
  input     Json     @default("{}")
  output    Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placeId])
  @@index([status, type])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// Posts sociaux — photos, likes, commentaires (style Instagram)
// ----------------------------------------------------------------------------

model Post {
  id         String        @id @default(uuid())
  userId     String
  caption    String?
  placeId    String?
  mediaUrls  String[]
  videoUrl   String?       // URL vidéo uploadée (optionnel)
  musicTrack String?       // ex: "Blinding Lights - The Weeknd"
  likesCount Int           @default(0)
  viewsCount Int           @default(0)  // stats : nombre de vues
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  // Gestion de contenu (façon Instagram)
  pinned           Boolean   @default(false) // épinglé en haut du profil (max 3 côté service)
  archived         Boolean   @default(false) // masqué sans suppression
  isDraft          Boolean   @default(false) // brouillon non publié
  editedAt         DateTime?                 // dernière modification de la légende
  commentsDisabled Boolean   @default(false)
  hideLikeCount    Boolean   @default(false)
  coverUrl         String?                   // couverture choisie pour un reel/vidéo
  taggedUserIds    String[]  @default([])    // personnes identifiées
  collabUserId     String?                   // co-auteur (post en collaboration)
  hashtags         String[]  @default([])    // extraits de la légende, pour la recherche

  likes      PostLike[]
  comments   PostComment[]
  saves      PostSave[]
  reposts    Repost[]

  @@index([userId])
  @@index([placeId])
  @@index([createdAt])
}

/// Enregistrement d'un post (bookmark) — comme « Enregistrer » sur Instagram.
model PostSave {
  postId       String
  userId       String
  collectionId String?  // rangé dans une collection (optionnel)
  createdAt    DateTime @default(now())
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
  @@index([collectionId])
}

/// Republication d'un post (repost) — comme le « Reposter » d'Instagram/X.
model Repost {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  caption   String?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@index([createdAt])
}

model PostLike {
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
}

model PostComment {
  id         String   @id @default(uuid())
  postId     String
  userId     String
  content    String
  parentId   String?  // réponse en fil à un autre commentaire
  likesCount Int      @default(0)
  pinned     Boolean  @default(false) // épinglé par l'auteur du post
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes      CommentLike[]

  @@index([postId])
  @@index([userId])
  @@index([parentId])
}

/// Like d'un commentaire.
model CommentLike {
  commentId String
  userId    String
  createdAt DateTime    @default(now())
  comment   PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
}

// ----------------------------------------------------------------------------
// Meetups — événements sociaux créés par les utilisateurs
// ----------------------------------------------------------------------------

model MeetupEvent {
  id           String       @id @default(uuid())
  hostId       String
  title        String
  description  String?
  city         String
  placeId      String?
  date         DateTime
  maxAttendees Int?
  isPublic     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  rsvps        MeetupRsvp[]

  @@index([date])
  @@index([city])
  @@index([hostId])
}

model MeetupRsvp {
  meetupId String
  userId   String
  status   String      @default("going") // 'going' | 'maybe'
  joinedAt DateTime    @default(now())
  meetup   MeetupEvent @relation(fields: [meetupId], references: [id], onDelete: Cascade)

  @@id([meetupId, userId])
  @@index([userId])
}

// ----------------------------------------------------------------------------
// Encounters — détection Happn-style (même lieu, proche dans le temps)
// ----------------------------------------------------------------------------

model Encounter {
  id        String   @id @default(uuid())
  userAId   String
  userBId   String
  placeId   String
  seenAt    DateTime @default(now())

  @@unique([userAId, userBId, placeId])
  @@index([userAId])
  @@index([userBId])
}

// ----------------------------------------------------------------------------
// Couche sociale — follows, chat, stories, localisation, quêtes
// ----------------------------------------------------------------------------

/// Abonnement entre deux utilisateurs (suivre/être suivi).
model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

/// Demande d'abonnement en attente vers un compte privé.
/// Acceptée → crée un Follow puis se supprime ; refusée → se supprime.
model FollowRequest {
  id          String   @id @default(uuid())
  requesterId String
  targetId    String
  createdAt   DateTime @default(now())

  @@unique([requesterId, targetId])
  @@index([targetId])
}

/// Collection de posts enregistrés (dossiers de bookmarks, façon Instagram).
model SavedCollection {
  id        String   @id @default(uuid())
  userId    String
  name      String
  coverUrl  String?
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Note éphémère (statut texte 24-72h affiché en haut des DM).
model Note {
  id        String   @id @default(uuid())
  userId    String   @unique // une seule note active par utilisateur
  text      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// Blocage : plus aucune interaction ni visibilité entre les deux comptes.
model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

/// Restriction discrète : ses commentaires ne sont visibles que par lui.
model Restrict {
  userId       String
  restrictedId String
  createdAt    DateTime @default(now())

  @@id([userId, restrictedId])
}

/// Masquer (mute) les posts et/ou stories d'un compte sans se désabonner.
model Mute {
  userId      String
  mutedId     String
  mutePosts   Boolean  @default(true)
  muteStories Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@id([userId, mutedId])
}

/// Signalement d'un contenu ou d'un compte.
model Report {
  id         String   @id @default(uuid())
  reporterId String
  targetType String   // 'post' | 'comment' | 'story' | 'user' | 'message'
  targetId   String
  reason     String
  details    String?
  status     String   @default("pending") // 'pending' | 'reviewed' | 'dismissed'
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([status])
}

/// Ami proche : accès aux stories « close friends ».
model CloseFriend {
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  @@id([userId, friendId])
}

/// Compte favori : ses posts sont priorisés dans le feed.
model FavoriteUser {
  userId     String
  favoriteId String
  createdAt  DateTime @default(now())

  @@id([userId, favoriteId])
}

/// Conversation privée entre deux utilisateurs.
model Conversation {
  id           String                    @id @default(uuid())
  isGroup      Boolean                   @default(false)
  title        String?                   // nom du groupe
  photoUrl     String?                   // photo du groupe
  creatorId    String?                   // créateur du groupe
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

enum MessageType {
  text
  image
  video
  audio
  place_share
  location_share
  post_share
  story_reply
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType @default(text)
  mediaUrl       String?
  placeId        String?
  postId         String?     // post partagé en DM
  storyId        String?     // story à laquelle on répond
  replyToId      String?     // réponse à un message précis
  durationSec    Int?        // durée d'un message vocal
  oneTime        Boolean     @default(false) // vue unique (photo/vidéo éphémère)
  viewedOnceAt   DateTime?   // consommé (vue unique)
  createdAt      DateTime    @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reactions      MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

/// Réaction emoji sur un message (une par utilisateur et par message).
model MessageReaction {
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
}

/// Story éphémère (disparaît après 24h) — photo ou vidéo courte.
enum StoryType {
  photo
  video
}

model Story {
  id               String    @id @default(uuid())
  userId           String
  mediaUrl         String
  type             StoryType @default(photo)
  caption          String?
  placeId          String?
  expiresAt        DateTime
  viewCount        Int       @default(0)
  closeFriendsOnly Boolean   @default(false) // visible uniquement par les amis proches
  stickers         Json?     // stickers posés sur la story : sondage, question, mention, lieu, texte… [{ kind, x, y, ... }]
  createdAt        DateTime  @default(now())
  views            StoryView[]
  pollVotes        StoryPollVote[]

  @@index([userId])
  @@index([expiresAt])
}

/// Vote sur le sticker sondage/quiz d'une story.
model StoryPollVote {
  storyId     String
  userId      String
  optionIndex Int
  createdAt   DateTime @default(now())
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
}

model StoryView {
  storyId  String
  userId   String
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
}

/// Story « à la une » épinglée sur le profil (survit aux 24h). Regroupe des médias.
model StoryHighlight {
  id        String                @id @default(uuid())
  userId    String
  title     String
  coverUrl  String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  items     StoryHighlightItem[]

  @@index([userId])
}

model StoryHighlightItem {
  id          String         @id @default(uuid())
  highlightId String
  mediaUrl    String
  type        StoryType      @default(photo)
  caption     String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  highlight   StoryHighlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  @@index([highlightId])
}

/// Défi / quête à accomplir pour gagner de l'XP et des badges.
model Quest {
  id          String   @id @default(uuid())
  title       String
  description String
  emoji       String   @default("🏆")
  type        String   // 'universe_visit' | 'review_count' | 'visit_count' | 'friend_count' | 'swipe_count'
  target      Int
  universe    String?
  xpReward    Int      @default(100)
  badgeId     String?
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  userProgress UserQuest[]

  @@index([isActive])
}

model UserQuest {
  id          String   @id @default(uuid())
  userId      String
  questId     String
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
  @@index([userId])
  @@index([questId])
}

/// Guide de randonnée local certifié — réservable (commission 20%).
model Guide {
  id             String         @id @default(uuid())
  name           String
  city           String
  countryCode    String
  certified      Boolean        @default(false)
  pricePerPerson Float
  rating         Float          @default(0)
  bio            String?
  createdAt      DateTime       @default(now())

  bookings       GuideBooking[]

  @@index([city])
}

/// Réservation d'un guide de randonnée (commission 20%).
model GuideBooking {
  id         String   @id @default(uuid())
  guideId    String
  guide      Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  userId     String?
  date       DateTime
  people     Int      @default(1)
  totalPrice Float
  commission Float    // part YUMIA (20%)
  status     String   @default("pending") // pending | confirmed | cancelled
  createdAt  DateTime @default(now())

  @@index([guideId])
  @@index([userId])
}
