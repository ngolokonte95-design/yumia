// YUMIA — Schéma PostgreSQL (source de vérité).
// PostgreSQL = vérité ; Elasticsearch = index de recherche dérivé ; Redis = cache.
// Conçu multi-pays / multi-langue dès le départ.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Utilisateurs & authentification
// ----------------------------------------------------------------------------

enum Plan {
  free
  plus
}

enum AuthProvider {
  password
  google
  apple
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  displayName  String
  bio          String?
  photoUrl     String?
  authProvider AuthProvider @default(password)
  passwordHash String?
  appleId      String?      @unique

  // i18n / contexte
  locale       String       @default("fr")
  currency     String       @default("EUR")
  countryCode  String?
  timezone     String?

  plan         Plan         @default(free)
  // Abonnement Premium (RevenueCat). `plan` reste synchro (plus = premium).
  isPremium    Boolean      @default(false)
  premiumSince DateTime?
  premiumPlan  String?      // 'monthly' | 'annual'
  totalXp      Int          @default(0)
  level        Int          @default(1)

  // Préférences (restrictions, univers favoris) — flexibles, donc JSON.
  preferences    Json         @default("{}")
  expoPushToken  String?

  // Profil social
  gender         String?      // 'male' | 'female' | 'other'
  birthYear      Int?         // année de naissance → âge calculé côté client
  interestedIn   String       @default("everyone") // 'male' | 'female' | 'everyone'

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  visits              Visit[]
  savedPlaces         SavedPlace[]
  earnedBadges        EarnedBadge[]
  streak              Streak?
  groupSessions       GroupMember[]

  @@index([countryCode])
  @@index([expoPushToken])
  @@index([gender])
  @@index([interestedIn])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ----------------------------------------------------------------------------
// Lieux (POI) — 14 univers
// ----------------------------------------------------------------------------

enum Universe {
  // Manger & Boire
  restaurant    // inclut fast_food (fusionné)
  cafe
  bakery
  fast_food     // LEGACY — fusionné dans restaurant (migration 20260708180000)
  dessert
  ice_cream
  chocolatier
  bubble_tea
  wine_cellar
  tea_house
  local_specialty
  // Bars & Soirées
  bar
  pub
  nightclub
  hookah
  live_music
  rooftop
  karaoke
  // Culture & Tourisme
  museum
  monument
  tourist_activity
  cultural_outing
  cinema
  zoo
  amusement_park
  photo_spot
  // Nature & Plein air
  park
  beach
  // Sport & Loisirs
  fitness       // inclut padel/tennis (fusionné)
  gym
  aquatic
  padel         // LEGACY — fusionné dans fitness (migration 20260708180000)
  escape_game
  laser_game
  karting
  bowling
  casino
  // Bien-être & Beauté
  spa
  massage
  nail_salon
  hair_salon
  barber
  florist
  // Shopping & Commerce
  shopping
  mall
  market
  bookstore
  jewelry
  // Santé
  pharmacy
  doctor
  hospital
  vet
  optician
  // Culte & Services
  police
  fuel
  laundry
  place_of_worship
  library
  coworking
  // Sport urbain
  skatepark
  // Cannabis
  cannabis
  // Transport & Hébergement
  gare
  hotel
  event_venue
  // Valeurs héritées (non affichées dans l'UI — migration impossible en PG)
  nightlife
  art_gallery
  cheese_shop
}

model Place {
  id          String   @id @default(uuid())
  name        String
  universe    Universe

  lat         Float
  lng         Float
  city        String
  countryCode String

  rating      Float    @default(0)
  priceTier   Int      @default(2) // 1..4
  photoUrls   String[] @default([])

  // Attributs exploités par les moteurs IA (terrasse, kid_friendly, halal…).
  tags        String[] @default([])
  metadata    Json     @default("{}")

  // Provenance : 'seed' (données locales) ou 'google' (hydraté à la demande).
  // providerPlaceId déduplique les lieux importés (NULL pour les lieux seed).
  provider        String  @default("seed")
  providerPlaceId String? @unique
  address         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  visits      Visit[]
  savedBy     SavedPlace[]

  @@index([universe])
  @@index([city, universe])
  @@index([countryCode])
  // Bounding-box pre-filter for geo queries (nearbyViaPg, trending)
  @@index([lat, lng])
}

// ----------------------------------------------------------------------------
// Activité utilisateur : visites, sauvegardes
// ----------------------------------------------------------------------------

enum VisitFeedback {
  loved // 😍
  neutral // 😐
  disliked // 😕
}

model Visit {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place          @relation(fields: [placeId], references: [id], onDelete: Cascade)
  visitedAt DateTime       @default(now())
  feedback  VisitFeedback?
  xpAwarded Int            @default(0)
  notes     String?

  @@index([userId, visitedAt])
  @@index([placeId])
}

model SavedPlace {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  listName  String   @default("a_essayer")
  createdAt DateTime @default(now())

  @@unique([userId, placeId, listName])
  @@index([userId])
}

// ----------------------------------------------------------------------------
// Gamification : badges, streaks
// ----------------------------------------------------------------------------

model EarnedBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey  String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeKey])
  @@index([userId])
}

model Streak {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  current         Int      @default(0)
  best            Int      @default(0)
  lastActivityDay DateTime?
  freezesLeft     Int      @default(0) // YUMIA Plus
  updatedAt       DateTime @updatedAt

  // Optimise la requête cron "danger de streak" qui filtre sur current > 0 + lastActivityDay
  @@index([current, lastActivityDay])
}

// ----------------------------------------------------------------------------
// Réinitialisation de mot de passe
// ----------------------------------------------------------------------------

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ----------------------------------------------------------------------------
// Group Mode (viralité intégrée)
// ----------------------------------------------------------------------------

enum GroupStatus {
  waiting    // en attente que d'autres rejoignent
  voting     // l'hôte a lancé les suggestions, vote en cours
  done       // un lieu a été choisi
}

model GroupSession {
  id             String      @id @default(uuid())
  inviteCode     String      @unique
  status         GroupStatus @default(waiting)
  createdById    String?
  suggestions    Json        @default("[]") // PlaceId[]
  decidedPlaceId String?
  createdAt      DateTime    @default(now())
  members        GroupMember[]

  @@index([inviteCode])
  // Optimise le cron de nettoyage : filtre sur status + createdAt
  @@index([status, createdAt])
}

model GroupMember {
  id        String       @id @default(uuid())
  sessionId String
  session   GroupSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Votes : { placeId: 'like' | 'dislike' }
  votes     Json         @default("{}")
  joinedAt  DateTime     @default(now())

  @@index([sessionId])
}

// ----------------------------------------------------------------------------
// Modèle économique : partenariats établissements, billetterie, guides
// ----------------------------------------------------------------------------

/// Établissement partenaire — boost payant des suggestions + billetterie.
model Venue {
  id             String    @id @default(uuid())
  placeId        String?   // lien optionnel vers un Place existant
  name           String
  city           String?
  countryCode    String?
  // Boost des suggestions : 0 = aucun, 3 = maximal. Expire à boostExpiresAt.
  boostLevel     Int       @default(0)
  boostExpiresAt DateTime?
  businessPlan   String    @default("basic") // basic | pro | enterprise
  commissionRate Float     @default(0.15)
  /// Événement mis en avant pour la billetterie (optionnel).
  eventName      String?
  eventDate      DateTime?
  ticketPrice    Float?
  photoUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tickets        Ticket[]

  @@index([boostLevel])
  @@index([placeId])
}

/// Billet de club / soirée vendu via YUMIA (commission 15%).
model Ticket {
  id         String   @id @default(uuid())
  venueId    String
  venue      Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  eventId    String
  userId     String?
  quantity   Int      @default(1)
  unitPrice  Float
  totalPrice Float
  commission Float    // part YUMIA (15%)
  // paiement réel branché plus tard (Stripe) — statut applicatif pour l'instant
  status     String   @default("pending") // pending | paid | cancelled
  createdAt  DateTime @default(now())

  @@index([venueId])
  @@index([userId])
  @@index([eventId])
}

// ----------------------------------------------------------------------------
// Pipeline d'enrichissement — menus, événements, jobs
// ----------------------------------------------------------------------------

/// Carte des menus d'un lieu (une par lieu et par langue).
model PlaceMenu {
  id        String     @id @default(uuid())
  placeId   String
  language  String     @default("fr")
  source    String     @default("manual") // 'manual' | 'ai_extract' | 'scrape' | 'uber_eats'
  updatedAt DateTime   @updatedAt
  createdAt DateTime   @default(now())
  items     MenuItem[]

  @@unique([placeId, language])
  @@index([placeId])
}

/// Plat / boisson sur la carte d'un lieu.
model MenuItem {
  id          String    @id @default(uuid())
  menuId      String
  menu        PlaceMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float?
  currency    String    @default("EUR")
  category    String?   // 'entrée' | 'plat' | 'dessert' | 'boisson' | 'snack' | 'autre'
  photoUrl    String?
  tags        String[]  @default([])  // ['végétarien','halal','sans_gluten'…]
  available   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([menuId])
  @@index([menuId, category])
}

/// Événement lié à un lieu (concert, feu d'artifice, soirée thématique…).
model PlaceEvent {
  id          String   @id @default(uuid())
  placeId     String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  price       Float?
  currency    String   @default("EUR")
  ticketUrl   String?
  photoUrl    String?
  source      String   @default("manual") // 'manual' | 'ticketmaster' | 'eventbrite' | 'facebook'
  externalId  String?  // ID dans le système source (évite les doublons)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([placeId, source, externalId])
  @@index([placeId, startAt])
  @@index([startAt])
}

/// Avis utilisateur sur un lieu (texte + note 1-5).
model PlaceReview {
  id        String   @id @default(uuid())
  placeId   String
  userId    String
  rating    Int      // 1..5
  body      String?  // texte optionnel
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([placeId, userId])
  @@index([placeId])
  @@index([userId])
}

/// Suivi des jobs d'enrichissement (menu photo → IA, fetch événements…).
model EnrichmentJob {
  id        String   @id @default(uuid())
  placeId   String
  type      String   // 'menu_photo' | 'menu_scrape' | 'events_fetch' | 'photo_tag'
  status    String   @default("pending") // 'pending' | 'running' | 'done' | 'failed'
  input     Json     @default("{}")
  output    Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placeId])
  @@index([status, type])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// Posts sociaux — photos, likes, commentaires (style Instagram)
// ----------------------------------------------------------------------------

model Post {
  id         String        @id @default(uuid())
  userId     String
  caption    String?
  placeId    String?
  mediaUrls  String[]
  videoUrl   String?       // URL vidéo uploadée (optionnel)
  musicTrack String?       // ex: "Blinding Lights - The Weeknd"
  likesCount Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  likes      PostLike[]
  comments   PostComment[]

  @@index([userId])
  @@index([placeId])
  @@index([createdAt])
}

model PostLike {
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

// ----------------------------------------------------------------------------
// Meetups — événements sociaux créés par les utilisateurs
// ----------------------------------------------------------------------------

model MeetupEvent {
  id           String       @id @default(uuid())
  hostId       String
  title        String
  description  String?
  city         String
  placeId      String?
  date         DateTime
  maxAttendees Int?
  isPublic     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  rsvps        MeetupRsvp[]

  @@index([date])
  @@index([city])
  @@index([hostId])
}

model MeetupRsvp {
  meetupId String
  userId   String
  status   String      @default("going") // 'going' | 'maybe'
  joinedAt DateTime    @default(now())
  meetup   MeetupEvent @relation(fields: [meetupId], references: [id], onDelete: Cascade)

  @@id([meetupId, userId])
  @@index([userId])
}

// ----------------------------------------------------------------------------
// Encounters — détection Happn-style (même lieu, proche dans le temps)
// ----------------------------------------------------------------------------

model Encounter {
  id        String   @id @default(uuid())
  userAId   String
  userBId   String
  placeId   String
  seenAt    DateTime @default(now())

  @@unique([userAId, userBId, placeId])
  @@index([userAId])
  @@index([userBId])
}

// ----------------------------------------------------------------------------
// Couche sociale — follows, chat, stories, localisation, quêtes
// ----------------------------------------------------------------------------

/// Abonnement entre deux utilisateurs (suivre/être suivi).
model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

/// Conversation privée entre deux utilisateurs.
model Conversation {
  id           String                    @id @default(uuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

enum MessageType {
  text
  image
  place_share
  location_share
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType @default(text)
  mediaUrl       String?
  placeId        String?
  createdAt      DateTime    @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

/// Story éphémère (disparaît après 24h) — photo ou vidéo courte.
enum StoryType {
  photo
  video
}

model Story {
  id        String    @id @default(uuid())
  userId    String
  mediaUrl  String
  type      StoryType @default(photo)
  caption   String?
  placeId   String?
  expiresAt DateTime
  viewCount Int       @default(0)
  createdAt DateTime  @default(now())
  views     StoryView[]

  @@index([userId])
  @@index([expiresAt])
}

model StoryView {
  storyId  String
  userId   String
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
}

/// Défi / quête à accomplir pour gagner de l'XP et des badges.
model Quest {
  id          String   @id @default(uuid())
  title       String
  description String
  emoji       String   @default("🏆")
  type        String   // 'universe_visit' | 'review_count' | 'visit_count' | 'friend_count' | 'swipe_count'
  target      Int
  universe    String?
  xpReward    Int      @default(100)
  badgeId     String?
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  userProgress UserQuest[]

  @@index([isActive])
}

model UserQuest {
  id          String   @id @default(uuid())
  userId      String
  questId     String
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
  @@index([userId])
  @@index([questId])
}

/// Guide de randonnée local certifié — réservable (commission 20%).
model Guide {
  id             String         @id @default(uuid())
  name           String
  city           String
  countryCode    String
  certified      Boolean        @default(false)
  pricePerPerson Float
  rating         Float          @default(0)
  bio            String?
  createdAt      DateTime       @default(now())

  bookings       GuideBooking[]

  @@index([city])
}

/// Réservation d'un guide de randonnée (commission 20%).
model GuideBooking {
  id         String   @id @default(uuid())
  guideId    String
  guide      Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  userId     String?
  date       DateTime
  people     Int      @default(1)
  totalPrice Float
  commission Float    // part YUMIA (20%)
  status     String   @default("pending") // pending | confirmed | cancelled
  createdAt  DateTime @default(now())

  @@index([guideId])
  @@index([userId])
}
