# ── Base de données ──────────────────────────────────────────────────────────
POSTGRES_USER=yumia
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=yumia

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ── IA ────────────────────────────────────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth sociale ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_...
SMTP_FROM=noreply@yumia.app

# ── Stockage S3 ───────────────────────────────────────────────────────────────
# IMPORTANT : mettre STORAGE_PROVIDER=s3 en production (disk = fichiers perdus au redémarrage)
STORAGE_PROVIDER=s3
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=yumia-uploads
# URL publique des assets (CloudFront ou S3 public) — exposée dans photoUrls
STORAGE_PUBLIC_BASE_URL=https://cdn.yumia.app

# ── Elasticsearch (optionnel) ─────────────────────────────────────────────────
ELASTICSEARCH_URL=

# ── RevenueCat webhooks ───────────────────────────────────────────────────────
# Secret défini dans RevenueCat Dashboard → Integrations → Webhooks → Authorization header
REVENUECAT_WEBHOOK_SECRET=

# ── Sentry (crash reporting) ─────────────────────────────────────────────────
# Obtenir sur https://sentry.io → Settings → Projects → DSN
SENTRY_DSN=
# Injecté dans le build Expo (préfixe EXPO_PUBLIC_ = bundle client)
EXPO_PUBLIC_SENTRY_DSN=
# Tag de release pour le source map Sentry (ex: 1.0.0-build.42)
SENTRY_RELEASE=

# ── EAS / Expo (CI secrets, ne pas mettre dans .env.prod) ────────────────────
# EXPO_TOKEN : créer sur expo.dev → Account → Access Tokens
# Ajouter comme secret GitHub : Settings → Secrets → EXPO_TOKEN

# ── Logging ──────────────────────────────────────────────────────────────────
# Niveau pino : trace | debug | info | warn | error (défaut : info en prod)
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yumia.app,https://www.yumia.app

# ── Docker image ─────────────────────────────────────────────────────────────
API_IMAGE=ghcr.io/yumia/yumia-api:latest
API_PORT=4000
