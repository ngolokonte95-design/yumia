{
  "name": "yumia",
  "version": "0.1.0",
  "private": true,
  "description": "YUMIA — Le Copilote IA Mondial des Expériences du Quotidien",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:shared": "npm run build --workspace @yumia/shared",
    "dev:api": "npm run start:dev --workspace @yumia/api",
    "dev:mobile": "npm run start --workspace @yumia/mobile",
    "generate-assets": "node scripts/generate-assets.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "sharp": "^0.33.5",
    "typescript": "^5.6.3"
  }
}
