# ============================================================
# YUMIA — Variables d'environnement (exemple)
# Copier vers .env et remplir. NE JAMAIS committer .env.
# ============================================================

# --- Application ---
NODE_ENV=development
API_PORT=4000
API_GLOBAL_PREFIX=api
DEFAULT_LOCALE=fr
DEFAULT_CURRENCY=EUR

# --- PostgreSQL ---
DATABASE_URL=postgresql://yumia:yumia@localhost:5432/yumia?schema=public

# --- Redis (cache + rate limit + sessions IA) ---
REDIS_URL=redis://localhost:6379

# --- Elasticsearch (recherche de lieux) ---
ELASTICSEARCH_NODE=http://localhost:9200

# --- IA (architecture multi-modèles) ---
# Fournisseur principal : anthropic | mock
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Modèle "smart" (raisonnement, Experience Builder) et "fast" (suggestions temps réel)
AI_MODEL_SMART=claude-sonnet-4-6
AI_MODEL_FAST=claude-haiku-4-5
# Budget tokens de sortie par défaut
AI_MAX_TOKENS=1024

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
GOOGLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_ID=

# --- Cartographie (interchangeable) ---
MAPS_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

# --- AWS / Stockage ---
AWS_REGION=eu-west-3
AWS_S3_BUCKET=yumia-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Observabilité ---
SENTRY_DSN=
POSTHOG_API_KEY=

# --- Notifications ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Achats in-app (RevenueCat) ---
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
